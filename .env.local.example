# ==============================================================================
# MissedCall Rescue AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ------------------------------------------------------------------------------
# Twilio
# Get these from: https://console.twilio.com
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC<your-account-sid>
TWILIO_AUTH_TOKEN=<your-auth-token>
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# The webhook URL Twilio will POST to on missed calls/SMS
# In production: https://your-domain.com/api/webhooks/twilio
TWILIO_WEBHOOK_URL=http://localhost:3000/api/webhooks/twilio

# ------------------------------------------------------------------------------
# OpenAI
# Get this from: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# Webhook Security
# A secret string used to verify Twilio webhook signatures
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------------------------
WEBHOOK_SECRET=<generate-a-random-secret>
